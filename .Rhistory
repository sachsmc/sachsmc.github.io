library(rvest)
parse_element <- function(node) {
main <- html_element(node, ".gsc_a_t")
year <- html_element(node, ".gsc_a_y") |> html_text()
title <- main  |> html_element("a") |> html_text()
tmpcite <- main |> html_elements(".gs_gray") |> html_text2()
authors_short <- tmpcite[1]
reference <- tmpcite[2]
link <- paste0("https://scholar.google.com", main  |> html_element("a") |> html_attr("href"))
authlist <- strsplit(authors_short, ", ")[[1]]
authtype <- "middle"
if(any(grepl("Sachs", authlist))) {
if(which(grepl("Sachs", authlist))[1] == 1){
authtype <- "first"
} else if(which(grepl("Sachs", authlist))[1] == length(authlist)) authtype <- "last"
} else {
subnode <- read_html(link)
longauth <- (html_element(subnode, "div.gsc_oci_field:contains(Authors) + div") |> html_text() |>
strsplit(", "))[[1]]
if(which(grepl("Sachs", longauth))[1] == length(longauth)) authtype <- "last"
}
data.frame(title = title, authors = authors_short, reference = reference, year = year, link = link,
authtype = authtype)
}
